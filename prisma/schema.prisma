generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id              String                    @id @default(uuid())
  name            String
  slug            String                    @unique
  phone           String?
  status          OrganizationStatus        @default(ACTIVE)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  activityEvents  ActivityEvent[]
  deals           Deal[]
  energyRequests  EnergyServiceRequest[]
  leads           Lead[]
  leadActivities  LeadActivity[]
  branding        OrganizationBranding?
  domains         OrganizationDomain[]
  homepage        OrganizationHomepage?
  subscription    OrganizationSubscription?
  ownerInvites    OwnerInvite[]
  tradeInCaptures TradeInCapture[]
  users           User[]
  vehicles        Vehicle[]
  inquiries       VehicleInquiry[]
  vehicleRequests VehicleRequest[]
}

model OrganizationHomepage {
  id                    String       @id @default(uuid())
  organizationId        String       @unique
  showPromo             Boolean      @default(false)
  promoText             String?      @db.VarChar(100)
  heroHeadline          String?      @db.VarChar(100)
  heroSubheadline       String?
  heroPrimaryCtaLabel   String?      @db.VarChar(30)
  heroPrimaryCtaRoute   String?      @default("inventory")
  showTrustHighlights   Boolean      @default(true)
  trustHighlightsJson   Json?
  showFeaturedInventory Boolean      @default(true)
  showTestimonial       Boolean      @default(false)
  testimonialQuote      String?
  testimonialAuthor     String?      @db.VarChar(100)
  showAboutTeaser       Boolean      @default(true)
  aboutTeaser           String?
  showContactCta        Boolean      @default(true)
  contactCtaHeadline    String?      @db.VarChar(100)
  contactCtaBody        String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationBranding {
  id              String       @id @default(uuid())
  organizationId  String       @unique
  logoUrl         String?
  primaryColor    String?      @default("#1A1A1A")
  heroHeadline    String?
  heroSubheadline String?
  aboutBlurb      String?
  contactEmail    String?
  contactPhone    String?
  address         String?
  socialImageUrl  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationDomain {
  id                String       @id @default(uuid())
  organizationId    String
  hostname          String       @unique
  isPrimary         Boolean      @default(false)
  status            DomainStatus @default(PENDING)
  verificationToken String       @unique
  verifiedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([hostname, status])
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  firstName             String
  lastName              String
  phone                 String?
  passwordHash          String?
  emailVerifiedAt       DateTime?
  role                  Role                   @default(CUSTOMER)
  isStub                Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  organizationId        String?
  twoFactorEnabled      Boolean                @default(false)
  twoFactorSecret       String?
  deals                 Deal[]
  energyServiceRequests EnergyServiceRequest[]
  assignedLeads         Lead[]                 @relation("LeadAssignee")
  customerLeads         Lead[]                 @relation("LeadCustomer")
  leadActivities        LeadActivity[]
  tradeInCaptures       TradeInCapture[]
  organization          Organization?          @relation(fields: [organizationId], references: [id])
  inquiries             VehicleInquiry[]
  vehicleRequests       VehicleRequest[]

  @@index([organizationId])
}

model Vehicle {
  id                   String             @id @default(uuid())
  vin                  String             @unique
  year                 Int
  make                 String
  model                String
  trim                 String?
  bodyStyle            String?
  fuelType             String?
  transmission         String?
  doors                Int?
  mileage              Int
  drivetrain           Drivetrain
  batteryRangeEstimate Int?
  batteryCapacityKWh   Float?
  batteryChemistry     String?
  chargingStandard     String?
  exteriorColor        String
  interiorColor        String
  titleStatus          TitleStatus
  price                Decimal            @db.Decimal(12, 2)
  description          String?
  highlights           String[]
  features             String[]
  internalNotes        String?
  vehicleStatus        VehicleStatus      @default(DRAFT)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  condition            InventoryCondition
  organizationId       String
  shares               Int                @default(0)
  views                Int                @default(0)
  deals                Deal[]
  leads                Lead[]
  tradeInCaptures      TradeInCapture[]
  organization         Organization       @relation(fields: [organizationId], references: [id])
  documents            VehicleDocument[]
  inquiries            VehicleInquiry[]
  media                VehicleMedia[]

  @@index([vehicleStatus])
  @@index([organizationId])
}

model VehicleMedia {
  id           String    @id @default(uuid())
  vehicleId    String
  mediaType    MediaType
  url          String
  displayOrder Int
  createdAt    DateTime  @default(now())
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehicleDocument {
  id            String   @id @default(uuid())
  vehicleId     String
  documentLabel String
  fileUrl       String
  uploadedAt    DateTime @default(now())
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehicleInquiry {
  id                String           @id @default(uuid())
  vehicleId         String
  userId            String?
  firstName         String
  lastName          String
  email             String
  phone             String
  preferredContact  ContactMethod
  message           String?
  tradeInInterest   Boolean          @default(false)
  financingInterest Boolean          @default(false)
  inquiryStatus     InquiryStatus    @default(NEW)
  ownerNotes        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  organizationId    String
  tradeInCaptures   TradeInCapture[]
  organization      Organization     @relation(fields: [organizationId], references: [id])
  user              User?            @relation(fields: [userId], references: [id])
  vehicle           Vehicle          @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([userId])
  @@index([organizationId])
  @@index([vehicleId, email, createdAt])
}

model TradeInCapture {
  id             String           @id @default(uuid())
  userId         String?
  firstName      String
  lastName       String
  email          String
  phone          String
  vehicleId      String?
  inquiryId      String?
  year           Int
  make           String
  model          String
  trim           String?
  mileage        Int
  vin            String?
  notes          String?
  createdAt      DateTime         @default(now())
  condition      TradeInCondition
  organizationId String
  inquiry        VehicleInquiry?  @relation(fields: [inquiryId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  vehicle        Vehicle?         @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([inquiryId])
  @@index([organizationId])
}

model VehicleRequest {
  id                String               @id @default(uuid())
  userId            String
  make              String
  model             String
  yearMin           Int?
  yearMax           Int?
  budgetMax         Decimal              @db.Decimal(12, 2)
  mileageMax        Int?
  colorPrefs        String?
  features          String?
  timeline          String?
  financingInterest Boolean              @default(false)
  tradeInInterest   Boolean              @default(false)
  notes             String?
  requestStatus     VehicleRequestStatus @default(SUBMITTED)
  ownerNotes        String?
  priority          Priority?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  organizationId    String
  proposals         VehicleProposal[]
  organization      Organization         @relation(fields: [organizationId], references: [id])
  user              User                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
}

model VehicleProposal {
  id             String         @id @default(uuid())
  requestId      String
  vin            String?
  make           String
  model          String
  year           Int
  mileage        Int
  estimatedPrice Decimal        @db.Decimal(12, 2)
  proposalStatus ProposalStatus @default(PROPOSED)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  request        VehicleRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
}

model Deal {
  id             String                 @id @default(uuid())
  vehicleId      String
  userId         String
  dealStatus     DealStatus             @default(LEAD)
  purchasePrice  Decimal                @db.Decimal(12, 2)
  depositAmount  Decimal?               @db.Decimal(12, 2)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id])
  user           User                   @relation(fields: [userId], references: [id])
  vehicle        Vehicle                @relation(fields: [vehicleId], references: [id])
  deposits       DealDeposit[]
  documents      DealDocument[]
  envelopes      DocuSignEnvelope[]
  energyRequests EnergyServiceRequest[]

  @@index([vehicleId])
  @@index([userId])
  @@index([organizationId])
}

model DealDeposit {
  id               String        @id @default(uuid())
  dealId           String
  stripePaymentId  String?       @unique
  depositAmount    Decimal       @db.Decimal(12, 2)
  paymentStatus    PaymentStatus @default(PENDING)
  paymentTimestamp DateTime?
  deal             Deal          @relation(fields: [dealId], references: [id])

  @@index([dealId])
}

model DealDocument {
  id             String         @id @default(uuid())
  dealId         String
  documentType   String
  documentStatus DocumentStatus @default(PENDING)
  fileUrl        String?
  createdAt      DateTime       @default(now())
  deal           Deal           @relation(fields: [dealId], references: [id])

  @@index([dealId])
}

model DocuSignEnvelope {
  id             String         @id @default(uuid())
  dealId         String
  envelopeId     String         @unique
  envelopeStatus EnvelopeStatus @default(SENT)
  sentAt         DateTime       @default(now())
  completedAt    DateTime?
  deal           Deal           @relation(fields: [dealId], references: [id])

  @@index([dealId])
}

model EnergyServiceRequest {
  id              String                       @id @default(uuid())
  userId          String
  dealId          String?
  serviceType     EnergyServiceType
  serviceStatus   EnergyServiceStatus          @default(INTEREST_CAPTURED)
  propertyAddress String
  notes           String?
  createdAt       DateTime                     @default(now())
  organizationId  String
  deal            Deal?                        @relation(fields: [dealId], references: [id])
  organization    Organization                 @relation(fields: [organizationId], references: [id])
  user            User                         @relation(fields: [userId], references: [id])
  statusHistory   EnergyServiceStatusHistory[]

  @@index([userId])
  @@index([dealId])
  @@index([organizationId])
}

model EnergyServiceStatusHistory {
  id        String               @id @default(uuid())
  requestId String
  status    EnergyServiceStatus
  changedBy String?
  timestamp DateTime             @default(now())
  request   EnergyServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model ActivityEvent {
  id             String        @id @default(uuid())
  eventType      String
  actorId        String?
  actorRole      Role?
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime      @default(now())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([entityType, entityId])
  @@index([organizationId])
}

model BetaAccessRequest {
  id               String           @id @default(uuid())
  dealershipName   String
  contactName      String
  email            String
  phone            String
  status           BetaAccessStatus @default(PENDING)
  rejectionReason  String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  organizationId   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
}

model OwnerInvite {
  id             String       @id @default(uuid())
  email          String
  organizationId String
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  lastSentAt     DateTime?
  tokenHash      String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model Lead {
  id             String         @id @default(uuid())
  organizationId String
  customerId     String?
  vehicleId      String?
  assignedToId   String?
  status         LeadStatus     @default(NEW)
  source         LeadSource
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  lastActivityAt DateTime?      @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedTo     User?          @relation("LeadAssignee", fields: [assignedToId], references: [id])
  customer       User?          @relation("LeadCustomer", fields: [customerId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?       @relation(fields: [vehicleId], references: [id])
  activities     LeadActivity[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, lastActivityAt])
}

model LeadActivity {
  id             String           @id @default(uuid())
  leadId         String
  organizationId String
  actorUserId    String?
  type           LeadActivityType
  body           String?
  metadataJson   Json?
  createdAt      DateTime         @default(now())
  actorUser      User?            @relation(fields: [actorUserId], references: [id])
  lead           Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([organizationId, createdAt])
}

model OrganizationSubscription {
  id                   String             @id @default(uuid())
  organizationId       String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  planKey              PlanKey?
  status               SubscriptionStatus @default(NONE)
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum Role {
  OWNER
  CUSTOMER
  SUPER_ADMIN
  STAFF
}

enum BetaAccessStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum VehicleStatus {
  DRAFT
  LISTED
  RESERVED
  UNDER_CONTRACT
  SOLD
  ARCHIVED
}

enum Drivetrain {
  AWD
  RWD
  FWD
}

enum InventoryCondition {
  EXCELLENT
  GOOD
  FAIR
}

enum TradeInCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum TitleStatus {
  CLEAN
  SALVAGE
  REBUILT
  LEMON
}

enum MediaType {
  IMAGE
  VIDEO
}

enum InquiryStatus {
  NEW
  REVIEWED
  RESPONDED
  CONVERTED
  CLOSED
}

enum VehicleRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  SOURCING
  VEHICLE_PROPOSED
  CUSTOMER_APPROVED
  CONVERTED_TO_DEAL
  CLOSED
}

enum ProposalStatus {
  PROPOSED
  CUSTOMER_ACCEPTED
  CUSTOMER_DECLINED
  EXPIRED
}

enum DealStatus {
  LEAD
  DEPOSIT_PENDING
  DEPOSIT_RECEIVED
  DOCUMENTS_PENDING
  CONTRACTS_SENT
  CONTRACTS_SIGNED
  FINANCING_PENDING
  READY_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
}

enum EnvelopeStatus {
  SENT
  DELIVERED
  COMPLETED
  VOIDED
}

enum ContactMethod {
  EMAIL
  PHONE
  EITHER
}

enum EnergyServiceType {
  EV_CHARGER
  SOLAR
}

enum EnergyServiceStatus {
  INTEREST_CAPTURED
  SUBMITTED_TO_BAYTECH
  ACKNOWLEDGED
  CONTACT_PENDING
  CLOSED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT
  NEGOTIATING
  WON
  LOST
}

enum LeadSource {
  INQUIRY
  VEHICLE_REQUEST
  RESERVATION
  MANUAL
}

enum LeadActivityType {
  NOTE
  STAGE_CHANGE
  INBOUND
  ASSIGNMENT
  SYSTEM
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum PlanKey {
  STARTER
  PRO
  PREMIUM
}
