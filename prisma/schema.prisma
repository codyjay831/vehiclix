// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  vehicles        Vehicle[]
  deals           Deal[]
  inquiries       VehicleInquiry[]
  vehicleRequests VehicleRequest[]
  activityEvents  ActivityEvent[]
  tradeInCaptures TradeInCapture[]
  energyRequests  EnergyServiceRequest[]
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  firstName        String
  lastName         String
  phone            String?
  passwordHash     String? // null for stub accounts
  emailVerifiedAt  DateTime? // null if not verified
  role             Role      @default(CUSTOMER)
  isStub           Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String? // Encrypted base32 secret
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Tenant ownership (optional for Customers, required for Staff/Owners in Phase 2 logic)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  deals                 Deal[]
  vehicleRequests       VehicleRequest[]
  energyServiceRequests EnergyServiceRequest[]
  inquiries             VehicleInquiry[]
  tradeInCaptures       TradeInCapture[]

  @@index([organizationId])
}

model Vehicle {
  id                   String             @id @default(uuid())
  vin                  String             @unique
  year                 Int
  make                 String
  model                String
  trim                 String?
  mileage              Int
  drivetrain           Drivetrain
  batteryRangeEstimate Int?
  exteriorColor        String
  interiorColor        String
  condition            InventoryCondition
  titleStatus          TitleStatus
  price                Decimal            @db.Decimal(12, 2)
  description          String?
  highlights           String[] // array of highlight strings
  features             String[] // selected feature checklist items
  internalNotes        String?
  vehicleStatus        VehicleStatus      @default(DRAFT)
  views                Int                @default(0)
  shares               Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  media           VehicleMedia[]
  documents       VehicleDocument[]
  inquiries       VehicleInquiry[]
  deals           Deal[]
  tradeInCaptures TradeInCapture[]

  @@index([vehicleStatus])
  @@index([organizationId])
}

model VehicleMedia {
  id           String    @id @default(uuid())
  vehicleId    String
  mediaType    MediaType
  url          String
  displayOrder Int
  createdAt    DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehicleDocument {
  id            String   @id @default(uuid())
  vehicleId     String
  documentLabel String
  fileUrl       String
  uploadedAt    DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehicleInquiry {
  id                String        @id @default(uuid())
  vehicleId         String
  userId            String? // optional link to a registered user
  firstName         String // denormalized submitted info
  lastName          String
  email             String
  phone             String
  preferredContact  ContactMethod
  message           String?
  tradeInInterest   Boolean       @default(false)
  financingInterest Boolean       @default(false)
  inquiryStatus     InquiryStatus @default(NEW)
  ownerNotes        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id])
  user            User?            @relation(fields: [userId], references: [id])
  tradeInCaptures TradeInCapture[]

  @@index([vehicleId])
  @@index([userId])
  @@index([organizationId])
  @@index([vehicleId, email, createdAt])
}

model TradeInCapture {
  id            String           @id @default(uuid())
  userId        String? // optional link to a registered user
  firstName     String // denormalized submitted info
  lastName      String
  email         String
  phone         String
  vehicleId     String? // the vehicle being viewed (context)
  inquiryId     String? // linked inquiry if applicable
  year          Int
  make          String
  model         String
  trim          String?
  mileage       Int
  vin           String?
  condition     TradeInCondition
  notes         String?
  createdAt     DateTime         @default(now())

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  user    User?           @relation(fields: [userId], references: [id])
  vehicle Vehicle?        @relation(fields: [vehicleId], references: [id])
  inquiry VehicleInquiry? @relation(fields: [inquiryId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([inquiryId])
  @@index([organizationId])
}

model VehicleRequest {
  id                String               @id @default(uuid())
  userId            String
  make              String
  model             String
  yearMin           Int?
  yearMax           Int?
  budgetMax         Decimal              @db.Decimal(12, 2)
  mileageMax        Int?
  colorPrefs        String?
  features          String?
  timeline          String?
  financingInterest Boolean              @default(false)
  tradeInInterest   Boolean              @default(false)
  notes             String?
  requestStatus     VehicleRequestStatus @default(SUBMITTED)
  ownerNotes        String?
  priority          Priority?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  user      User              @relation(fields: [userId], references: [id])
  proposals VehicleProposal[]

  @@index([userId])
  @@index([organizationId])
}

model VehicleProposal {
  id             String         @id @default(uuid())
  requestId      String
  vin            String?
  make           String
  model          String
  year           Int
  mileage        Int
  estimatedPrice Decimal        @db.Decimal(12, 2)
  proposalStatus ProposalStatus @default(PROPOSED)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  request VehicleRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
}

model Deal {
  id            String     @id @default(uuid())
  vehicleId     String
  userId        String
  dealStatus    DealStatus @default(LEAD)
  purchasePrice Decimal    @db.Decimal(12, 2)
  depositAmount Decimal?   @db.Decimal(12, 2)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  vehicle        Vehicle                @relation(fields: [vehicleId], references: [id])
  user           User                   @relation(fields: [userId], references: [id])
  deposits       DealDeposit[]
  documents      DealDocument[]
  envelopes      DocuSignEnvelope[]
  energyRequests EnergyServiceRequest[]

  @@index([vehicleId])
  @@index([userId])
  @@index([organizationId])
}

model DealDeposit {
  id               String        @id @default(uuid())
  dealId           String
  stripePaymentId  String?       @unique
  depositAmount    Decimal       @db.Decimal(12, 2)
  paymentStatus    PaymentStatus @default(PENDING)
  paymentTimestamp DateTime?

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
}

model DealDocument {
  id             String         @id @default(uuid())
  dealId         String
  documentType   String
  documentStatus DocumentStatus @default(PENDING)
  fileUrl        String?
  createdAt      DateTime       @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
}

model DocuSignEnvelope {
  id             String         @id @default(uuid())
  dealId         String
  envelopeId     String         @unique
  envelopeStatus EnvelopeStatus @default(SENT)
  sentAt         DateTime       @default(now())
  completedAt    DateTime?

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
}

model EnergyServiceRequest {
  id              String              @id @default(uuid())
  userId          String
  dealId          String?
  serviceType     EnergyServiceType
  serviceStatus   EnergyServiceStatus @default(INTEREST_CAPTURED)
  propertyAddress String
  notes           String?
  createdAt       DateTime            @default(now())

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  user          User                         @relation(fields: [userId], references: [id])
  deal          Deal?                        @relation(fields: [dealId], references: [id])
  statusHistory EnergyServiceStatusHistory[]

  @@index([userId])
  @@index([dealId])
  @@index([organizationId])
}

model EnergyServiceStatusHistory {
  id        String              @id @default(uuid())
  requestId String
  status    EnergyServiceStatus
  changedBy String? // User ID of owner who changed it
  timestamp DateTime            @default(now())

  request EnergyServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model ActivityEvent {
  id         String   @id @default(uuid())
  eventType  String
  actorId    String?
  actorRole  Role?
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  // Tenant ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([entityType, entityId])
  @@index([organizationId])
}

// --- ENUMS ---

enum Role {
  OWNER
  CUSTOMER
}

enum VehicleStatus {
  DRAFT
  LISTED
  RESERVED
  UNDER_CONTRACT
  SOLD
  ARCHIVED
}

enum Drivetrain {
  AWD
  RWD
  FWD
}

enum InventoryCondition {
  EXCELLENT
  GOOD
  FAIR
}

enum TradeInCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum TitleStatus {
  CLEAN
  SALVAGE
  REBUILT
  LEMON
}

enum MediaType {
  IMAGE
  VIDEO
}

enum InquiryStatus {
  NEW
  REVIEWED
  RESPONDED
  CONVERTED
  CLOSED
}

enum VehicleRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  SOURCING
  VEHICLE_PROPOSED
  CUSTOMER_APPROVED
  CONVERTED_TO_DEAL
  CLOSED
}

enum ProposalStatus {
  PROPOSED
  CUSTOMER_ACCEPTED
  CUSTOMER_DECLINED
  EXPIRED
}

enum DealStatus {
  LEAD
  DEPOSIT_PENDING
  DEPOSIT_RECEIVED
  DOCUMENTS_PENDING
  CONTRACTS_SENT
  CONTRACTS_SIGNED
  FINANCING_PENDING
  READY_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
}

enum EnvelopeStatus {
  SENT
  DELIVERED
  COMPLETED
  VOIDED
}

enum ContactMethod {
  EMAIL
  PHONE
  EITHER
}

enum EnergyServiceType {
  EV_CHARGER
  SOLAR
}

enum EnergyServiceStatus {
  INTEREST_CAPTURED
  SUBMITTED_TO_BAYTECH
  ACKNOWLEDGED
  CONTACT_PENDING
  CLOSED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}
